{
  "name": "relayburn",
  "private": true,
  "version": "0.0.0",
  "description": "Token usage & cost attribution for agent CLIs",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc --build",
    "test": "node --test --test-reporter=spec 'packages/*/dist/**/*.test.js'",
    "test:ts": "tsc --build && npm run test",
    "clean": "tsc --build --clean",
    "pricing:update": "node scripts/update-pricing.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
