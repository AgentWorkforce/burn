{
  "name": "@relayburn/analyze",
  "version": "0.33.0",
  "description": "Cost and usage derivations for relayburn TurnRecords",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./pricing": "./dist/pricing.js",
    "./cost": "./dist/cost.js"
  },
  "files": [
    "dist",
    "pricing",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@relayburn/reader": "workspace:*",
